# Copy to .env and adjust as needed. All settings are optional; defaults shown below.

# BBLOCKS_DATABASE_PATH=./data/meta-register.db

# BBLOCKS_META_REGISTRY_INDEX_URL=https://w3id.org/ogc/bblocks/meta-register.json
# BBLOCKS_META_REGISTRY_ORGS_URL=https://w3id.org/ogc/bblocks/meta-register-orgs.json

# BBLOCKS_CRAWL_INTERVAL_SECONDS=3600
# BBLOCKS_CRAWL_ON_STARTUP=true
# BBLOCKS_CRAWL_WORKER_POOL_SIZE=3
# BBLOCKS_CRAWL_PER_HOST_MIN_INTERVAL_SECONDS=1.0

# BBLOCKS_HTTP_TIMEOUT_SECONDS=30.0
# BBLOCKS_HTTP_MAX_RETRIES=3

# Required header X-Admin-Api-Key on every /admin/* request once set. Unset = /admin is
# unprotected -- fine for local dev, but set this before deploying anywhere untrusted.
# BBLOCKS_ADMIN_API_KEY=

# Optional Host/Origin allowlist for /mcp. Unset (default) = open to any client, same as
# /orgs, /registers, /bblocks -- intentional, so any LLM tooling can reach it. Only set these
# if /mcp ever needs restricting to specific hosts/origins later.
# BBLOCKS_MCP_ALLOWED_HOSTS=meta-register.example.org
# BBLOCKS_MCP_ALLOWED_ORIGINS=https://meta-register.example.org
